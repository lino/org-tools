{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://org-tools.dev/schemas/org-clock-report-output.schema.json",
  "title": "org clock report JSON output",
  "description": "Schema for the JSON output of 'org clock report --format json'.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["label", "minutes", "duration"],
    "properties": {
      "label": {
        "type": "string",
        "description": "Label for this clock report row (entry title, date, tag, etc.)."
      },
      "minutes": {
        "type": "integer",
        "minimum": 0,
        "description": "Total clocked time in minutes."
      },
      "duration": {
        "type": "string",
        "description": "Human-readable duration string (e.g., '2h 30m')."
      },
      "file": {
        "type": "string",
        "description": "Path to the org file. Present when group_by=entry."
      }
    },
    "additionalProperties": false
  }
}
